# Database
*.sqlite
*.sqlite3
*.db
postgres-data/

# Uploaded artifacts (local FS storage in v1)
uploads/
var/

# The literal brace-expansion folder — left untracked until reviewed
{docs,modules,infra}/

# Eval harness run output and blessed baselines (large; admin-local)
modules/07-ai-grading/eval/runs/*/
modules/07-ai-grading/eval/baselines/*.json

# Lighthouse CI run artifacts (local; CI outputs to temporary-public-storage)
apps/web/.lighthouseci/

# Playwright HTML report and test-results artifacts (local viewer; not source)
apps/web/playwright-report/
apps/web/test-results/

# Lighthouse local run reports (root-level; CI uploads to temporary-public-storage)
lh-*.json

# Claude Code session artifacts (plans + worktree sandboxes — not source)
.claude/plans/
.claude/worktrees/

# Load-test run output (gitkeep tracks the dir, not the results)
tests/load/results/*
!tests/load/results/.gitkeep
