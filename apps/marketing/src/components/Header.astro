---
// Header.astro — site-wide navigation
// Logo mark: CSS-driven dot + halo (per branding guideline §6 "In-product Logo component — Path 1 decision")
// Wordmark: serif "AssessIQ" per branding guideline §6 (not "AccessIQ" — vendor-side typo)
// Nav: Home, Solutions (dropdown → 4 solution pages), Pricing, About, Contact + Sign in CTA
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/',        label: 'Home' },
  { href: '/about',   label: 'About' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/contact', label: 'Contact' },
];

const solutionLinks = [
  { href: '/solutions/it-hiring',                label: 'IT & Tech Hiring' },
  { href: '/solutions/campus-recruitment',       label: 'Campus Recruitment' },
  { href: '/solutions/educational-institutions', label: 'Educational Institutions' },
  { href: '/solutions/team-skill-gap',           label: 'Team Skill-Gap' },
];

// Treat any /solutions/* path as "Solutions" active
const isSolutionsActive = currentPath.startsWith('/solutions');
---

<header class="border-b border-aiq-border bg-aiq-bg-base sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-aiq-xl flex items-center justify-between h-14">

    <!-- Logo / Wordmark -->
    <a href="/" class="flex items-center gap-2 no-underline focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2 rounded-aiq-sm" aria-label="AssessIQ — home">
      <!-- CSS mark: filled accent dot + 1px halo at -4px inset, per branding §6 -->
      <span class="relative inline-block w-[10px] h-[10px] flex-shrink-0" aria-hidden="true">
        <span class="absolute inset-0 rounded-full bg-aiq-accent"></span>
        <span class="absolute rounded-full border border-aiq-accent/30" style="inset: -4px;"></span>
      </span>
      <!-- Serif wordmark: 18px weight-500 tracking -0.02em per branding guideline §6 -->
      <span class="font-serif text-[18px] font-medium tracking-aiq-tight text-aiq-fg-primary leading-none select-none">AssessIQ</span>
    </a>

    <!-- Primary nav -->
    <nav aria-label="Main navigation">
      <ul class="flex items-center gap-1 list-none m-0 p-0">

        <!-- Solutions — simple dropdown (CSS :focus-within, no JS) -->
        <li class="relative group">
          <button
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            class={[
              'font-sans text-aiq-sm font-medium px-3 py-1.5 rounded-aiq-pill transition-colors duration-150',
              'focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-1',
              'flex items-center gap-1 cursor-pointer border-0 bg-transparent',
              isSolutionsActive
                ? 'bg-aiq-bg-sunken text-aiq-fg-primary'
                : 'text-aiq-fg-secondary hover:text-aiq-fg-primary hover:bg-aiq-bg-raised',
            ].join(' ')}
          >
            Solutions
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true" class="mt-0.5 opacity-60">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <!-- Dropdown panel — shown on group-hover / group-focus-within -->
          <ul
            class="absolute left-0 top-full mt-1 min-w-[220px] bg-aiq-bg-base border border-aiq-border rounded-aiq-lg
                   shadow-aiq-md py-aiq-sm list-none m-0 p-aiq-sm
                   opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto
                   group-focus-within:opacity-100 group-focus-within:pointer-events-auto
                   transition-opacity duration-150 z-10"
            role="menu"
          >
            {solutionLinks.map(link => (
              <li role="none">
                <a
                  href={link.href}
                  role="menuitem"
                  aria-current={currentPath === link.href ? 'page' : undefined}
                  class={[
                    'block font-sans text-aiq-sm font-medium px-3 py-2 rounded-aiq-md transition-colors duration-150',
                    'focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-1',
                    currentPath === link.href
                      ? 'bg-aiq-bg-sunken text-aiq-fg-primary'
                      : 'text-aiq-fg-secondary hover:text-aiq-fg-primary hover:bg-aiq-bg-raised',
                  ].join(' ')}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </li>

        <!-- Standard nav links: Home, About, Pricing, Contact -->
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={currentPath === link.href ? 'page' : undefined}
              class={[
                'font-sans text-aiq-sm font-medium px-3 py-1.5 rounded-aiq-pill transition-colors duration-150',
                'focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-1',
                currentPath === link.href
                  ? 'bg-aiq-bg-sunken text-aiq-fg-primary'
                  : 'text-aiq-fg-secondary hover:text-aiq-fg-primary hover:bg-aiq-bg-raised',
              ].join(' ')}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA -->
    <a
      href="https://assessiq.in/admin/login"
      class="font-sans text-aiq-sm font-medium px-4 py-1.5 rounded-aiq-pill bg-aiq-accent text-white
             hover:bg-aiq-accent-hover transition-colors duration-150
             focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2"
    >
      Sign in
    </a>

  </div>
</header>
