---
// tests/aptitude.astro — Aptitude Online Test skill page (/tests/aptitude)
// JSON-LD: Service + FAQPage + BreadcrumbList (separate blocks per SEO §3.6 / §15)
// NO aggregateRating, NO fabricated stats
import BaseLayout from '../../layouts/BaseLayout.astro';

const site = 'https://assessiq.in';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Aptitude skills assessment",
  "provider": { "@type": "Organization", "name": "AssessIQ" },
  "areaServed": ["India", "Worldwide"],
  "description": "Online aptitude test for pre-employment screening and campus hiring in India. Covers numerical reasoning, data interpretation, time-speed-distance, percentages, and quantitative problem-solving. Structured scoring, anti-cheat proctoring, bulk invite.",
  "url": `${site}/tests/aptitude`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long is an aptitude test for campus hiring?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Campus aptitude tests on AssessIQ typically run 30–45 minutes for a 20–30 question MCQ format covering numerical reasoning, data interpretation, and quantitative problem-solving. Duration is configurable; some organisations run 60-minute tests with a wider question mix."
      }
    },
    {
      "@type": "Question",
      "name": "Is the aptitude test free on AssessIQ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The free tier allows you to run aptitude tests and review results. Bulk invite, concurrent session handling for campus drives, and advanced proctoring controls are part of paid plans. See the pricing page for current limits."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good aptitude test score for shortlisting?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shortlist thresholds depend on the role and competition in your candidate pool. For mass campus hiring in India, teams often shortlist the top 25–40% of applicants at the aptitude stage before moving to a technical screen. AssessIQ shows the cohort distribution per test run so you can set a percentile threshold rather than a fixed score."
      }
    },
    {
      "@type": "Question",
      "name": "Can the aptitude test be combined with a coding or English test?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A common campus hiring pattern combines aptitude, a coding question, and English comprehension in a single timed session. AssessIQ lets admins mix question packs from different skill areas within one test."
      }
    },
    {
      "@type": "Question",
      "name": "Is the aptitude test suitable for both engineering and non-engineering roles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Numerical reasoning and data interpretation questions are role-neutral. The quantitative difficulty level is adjustable: a junior operations analyst and a fresher engineer can be screened with different difficulty mixes from the same question bank."
      }
    },
    {
      "@type": "Question",
      "name": "Does AssessIQ aptitude test support bulk candidates for placement drives?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. AssessIQ supports CSV bulk invite, shareable test links, and concurrent session handling with no per-seat cap. Proctoring controls (tab-switch detection, webcam monitoring, full-screen enforcement) are active for all candidates simultaneously."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Skill Tests", "item": `${site}/tests` },
    { "@type": "ListItem", "position": 3, "name": "Aptitude Test" }
  ]
};

const topics = [
  { name: "Numerical reasoning", detail: "Arithmetic, ratio and proportion, percentage calculations, profit and loss, simple and compound interest — the quantitative core of every Indian campus placement test." },
  { name: "Data interpretation", detail: "Reading bar charts, pie charts, line graphs, and tables accurately. Identifying trends, computing derived values, and making valid inferences from incomplete data." },
  { name: "Time, speed, and distance", detail: "Train problems, relative speed, average speed over two legs, pipes and cisterns, work-rate problems — the classic categories that appear in TCS, Infosys, Wipro, and similar mass-hiring tests." },
  { name: "Algebra and number systems", detail: "Linear equations, simple quadratics, divisibility rules, HCF and LCM, prime factorisation, number properties, and digit-based problems." },
  { name: "Permutation and probability", detail: "Factorial-based counting, combinations vs permutations, basic probability (equally likely outcomes, conditional probability at introductory level), and seating/arrangement problems." },
  { name: "Series and sequences", detail: "Number series completion (arithmetic, geometric, mixed), letter-number sequences, and odd-one-out in a numerical pattern — overlaps with logical reasoning at the boundary." },
];
---

<BaseLayout
  title="Aptitude Online Test for Hiring & Assessment"
  description="Run an aptitude online test for campus hiring and fresher recruitment in India. Covers numerical reasoning, data interpretation, time-speed-distance, and quantitative problem-solving. Bulk invite, anti-cheat."
  canonicalPath="/tests/aptitude"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav aria-label="Breadcrumb" class="border-b border-aiq-border bg-aiq-bg-raised">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-sm">
      <ol class="flex items-center gap-aiq-sm list-none m-0 p-0">
        <li><a href="/" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">Home</a></li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li><a href="/tests" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">Skill Tests</a></li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li><span class="font-mono text-aiq-xs text-aiq-fg-secondary tracking-aiq-mono uppercase" aria-current="page">Aptitude Test</span></li>
      </ol>
    </div>
  </nav>

  <section class="bg-aiq-bg-base border-b border-aiq-border">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-lg m-0">Skill Test &middot; Aptitude</p>
      <h1 class="font-serif text-aiq-3xl sm:text-aiq-hero font-normal tracking-aiq-tighter text-aiq-fg-primary leading-[1.05] mb-aiq-xl mt-0 max-w-3xl">
        Aptitude Online Test for Hiring &amp; Assessment
      </h1>
      <p class="font-sans text-aiq-lg text-aiq-fg-secondary leading-relaxed mb-aiq-2xl max-w-2xl">
        An aptitude test measures a candidate's quantitative and analytical reasoning ability — numerical reasoning, data interpretation, and problem-solving under time pressure. In India's bulk hiring context, an aptitude screen is the first filter that separates candidates who can handle data-intensive work from those who cannot, before spending interviewer time on technical rounds.
      </p>
      <div class="flex flex-wrap items-center gap-aiq-md">
        <a href="https://assessiq.in/admin/login" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white hover:bg-aiq-accent-hover transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Get started free</a>
        <a href="/contact" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill border border-aiq-border-strong text-aiq-fg-primary hover:border-aiq-accent hover:text-aiq-accent transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Talk to us</a>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="topics-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Topic breakdown</p>
      <h2 id="topics-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">What the aptitude test covers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-aiq-lg">
        {topics.map(t => (
          <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
            <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">{t.name}</p>
            <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">{t.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-base border-b border-aiq-border" aria-labelledby="sample-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Sample question</p>
      <h2 id="sample-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">The kind of question candidates answer</h2>
      <div class="max-w-3xl">
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl mb-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md mt-0">Data interpretation — mid level</p>
          <p class="font-sans text-aiq-md text-aiq-fg-primary leading-relaxed mb-aiq-lg">
            A company's quarterly revenue (in lakhs): Q1 = 120, Q2 = 150, Q3 = 135, Q4 = 180.
            What is the percentage increase from the average of Q1 and Q2 to the average of Q3 and Q4?
          </p>
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Options</p>
          <ul class="list-none m-0 p-0 flex flex-col gap-aiq-sm font-sans text-aiq-md text-aiq-fg-secondary">
            <li>A. 10%</li>
            <li>B. 12.5%</li>
            <li class="text-aiq-accent font-medium">C. 16.67% &#10003; Correct</li>
            <li>D. 20%</li>
          </ul>
          <div class="mt-aiq-lg bg-aiq-bg-sunken border border-aiq-border rounded-aiq-md p-aiq-lg">
            <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Working</p>
            <p class="font-sans text-aiq-sm text-aiq-fg-secondary leading-relaxed m-0">
              Average Q1+Q2 = (120+150)/2 = 135. Average Q3+Q4 = (135+180)/2 = 157.5. Increase = (157.5-135)/135 &times; 100 = 22.5/135 &times; 100 = 16.67%.
            </p>
          </div>
        </div>
        <div class="bg-aiq-accent-soft border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">What this question tests</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Multi-step percentage calculation with an intermediate averaging step. Candidates who rush will compute the wrong base (using Q1 alone, or summing all four quarters). This pattern appears across analyst, operations, and management-trainee role assessments in India.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="roles-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Who should take it</p>
      <h2 id="roles-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Roles this test screens for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-aiq-lg max-w-4xl">
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Campus / Fresher Hiring</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">The standard first filter in Indian campus placement. Shortlist hundreds of applicants before technical rounds. Pair with an <a href="/tests/english" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">English test</a> and coding for a full drive pack.</p>
        </div>
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Analyst / Operations Roles</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Business analyst, operations analyst, and management-trainee screening. Numerical and data interpretation questions are directly predictive of on-the-job analytical work.</p>
        </div>
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Banking &amp; Finance</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Quantitative aptitude is a core competency for banking sector recruitment (BFSI). The numerical reasoning pack aligns with the quantitative section of standard BFSI screening batteries.</p>
        </div>
      </div>
      <p class="font-sans text-aiq-sm text-aiq-fg-muted leading-relaxed mt-aiq-xl mb-0">Relevant for <a href="/solutions/campus-recruitment" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">campus recruitment</a> and <a href="/solutions/it-hiring" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">IT &amp; technical hiring</a> in India.</p>
    </div>
  </section>

  <section class="bg-aiq-bg-base border-b border-aiq-border" aria-labelledby="format-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Format &amp; difficulty</p>
      <h2 id="format-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Duration, format, and difficulty levels</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-aiq-lg max-w-3xl">
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Duration</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">30–60 min</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Configurable per test</p>
        </div>
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Format</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">MCQ</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Single-correct, timed</p>
        </div>
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Levels</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">Foundation — Advanced</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Fresher to senior analyst</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="faq-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">FAQ</p>
      <h2 id="faq-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Common questions about the aptitude online test</h2>
      <div class="flex flex-col gap-aiq-xl max-w-3xl">
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">How long is an aptitude test for campus hiring?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Campus aptitude tests on AssessIQ typically run 30–45 minutes for a 20–30 question MCQ format. Duration is configurable; some organisations run 60-minute tests with a wider question mix.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Is the aptitude test free on AssessIQ?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">The free tier allows you to run aptitude tests and review results. Bulk invite and advanced proctoring are part of paid plans. See the <a href="/pricing" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">pricing page</a>.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">What is a good aptitude test score for shortlisting?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">For mass campus hiring, teams often shortlist the top 25–40% at the aptitude stage. AssessIQ shows the cohort distribution per test run so you can set a percentile threshold rather than a fixed score.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Can the aptitude test be combined with a coding or English test?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes. Combining aptitude, coding, and English in a single timed session is a common campus hiring pattern. AssessIQ lets admins mix question packs from different skill areas within one test.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Is the aptitude test suitable for both engineering and non-engineering roles?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes. Numerical reasoning and data interpretation questions are role-neutral. The quantitative difficulty level is adjustable for different role seniorities and domain contexts.</p></div>
        <div><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Does AssessIQ aptitude test support bulk candidates for placement drives?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes. AssessIQ supports CSV bulk invite, shareable test links, and concurrent session handling with no per-seat cap. Proctoring controls are active for all candidates simultaneously.</p></div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-base" aria-labelledby="related-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-aiq-4xl items-start">
        <div>
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Get started</p>
          <h2 class="font-serif text-aiq-2xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-xl mt-0">Ready to screen candidates on aptitude?</h2>
          <div class="flex flex-wrap gap-aiq-md">
            <a href="https://assessiq.in/admin/login" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white hover:bg-aiq-accent-hover transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Start free</a>
            <a href="/pricing" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill border border-aiq-border-strong text-aiq-fg-primary hover:border-aiq-accent hover:text-aiq-accent transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Pricing</a>
          </div>
        </div>
        <div>
          <p id="related-heading" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Related tests</p>
          <ul class="list-none m-0 p-0 flex flex-col gap-aiq-md">
            <li><a href="/tests/logical-reasoning" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">Logical Reasoning Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Pair with aptitude for a complete reasoning battery.</p></li>
            <li><a href="/tests/english" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">English Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Communication and comprehension screening for campus drives.</p></li>
            <li><a href="/tests/python" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">Python Online Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Add a coding screen for engineering campus hiring.</p></li>
            <li><a href="/tests" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">All skill tests &rarr;</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
