---
// tests/english.astro — English Online Test skill page (/tests/english)
// JSON-LD: Service + FAQPage + BreadcrumbList (separate blocks per SEO §3.6 / §15)
// NO aggregateRating, NO fabricated stats
import BaseLayout from '../../layouts/BaseLayout.astro';

const site = 'https://assessiq.in';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "English language skills assessment",
  "provider": { "@type": "Organization", "name": "AssessIQ" },
  "areaServed": ["India", "Worldwide"],
  "description": "Online English test for pre-employment screening in India. Covers grammar, vocabulary, reading comprehension, business writing, and verbal reasoning. Structured scoring, anti-cheat proctoring, bulk invite for campus hiring.",
  "url": `${site}/tests/english`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long is an English online test for hiring?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An English screening test on AssessIQ typically runs 20–40 minutes. A focused grammar and vocabulary set runs 15–20 minutes; adding reading comprehension passages and business-writing questions extends it to 30–45 minutes. Duration is configurable per test."
      }
    },
    {
      "@type": "Question",
      "name": "Is the English test free on AssessIQ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The free tier lets you run English tests and review candidate results. Higher candidate volumes, bulk invite, and advanced proctoring are part of paid plans. See the pricing page for current limits."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good score on an English test for a customer-facing role?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For customer success, sales, or support roles, strong comprehension and business-writing scores are more predictive than grammar MCQ performance. AssessIQ shows per-section breakdowns so you can weight sections by role requirement rather than using a single composite score as the cutoff."
      }
    },
    {
      "@type": "Question",
      "name": "Does the English test assess spoken English?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AssessIQ's English test is text-based (written format): grammar, vocabulary, comprehension, and written-response questions. Spoken English assessment requires a separate voice-recording or video interview tool. For roles where verbal communication is primary, we recommend pairing the written test with a structured panel interview."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use the English test for campus placement drives?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Combining an English section with aptitude and coding questions in a single timed session is a standard pattern for campus placement drives in India. AssessIQ's bulk invite and concurrent session handling support large simultaneous cohorts."
      }
    },
    {
      "@type": "Question",
      "name": "Is the English test suitable for screening BPO and operations roles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Grammar accuracy, reading speed and comprehension, and business-writing clarity are directly predictive of BPO and operations performance. The test can be configured to emphasise comprehension and written communication over advanced vocabulary, depending on the role."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Skill Tests", "item": `${site}/tests` },
    { "@type": "ListItem", "position": 3, "name": "English Test" }
  ]
};

const topics = [
  { name: "Grammar and usage", detail: "Subject-verb agreement, tense consistency, active vs passive voice, common error types (dangling modifiers, misplaced clauses), preposition choice, and article usage — the mechanical accuracy layer." },
  { name: "Vocabulary in context", detail: "Meaning from context, choosing the precise word among near-synonyms, collocations, phrasal verb meaning (especially in business contexts), and vocabulary at the level expected for professional English communication." },
  { name: "Reading comprehension", detail: "Main idea identification, explicit vs implicit information, inference from text, author tone and purpose, and speed-accuracy trade-off under timed conditions. Passages are 150–250 words, business or general professional context." },
  { name: "Business writing", detail: "Identifying formal vs informal register, correcting awkward or unclear sentences, choosing the right salutation and sign-off for a given context, and understanding email structure and clarity conventions for Indian professional settings." },
  { name: "Verbal reasoning", detail: "Sentence completion, analogy (word-relationship), rearranging jumbled sentences into a coherent paragraph, and para-jumbles — question types used in CAT, XAT, and Indian placement tests to assess structured verbal thinking." },
  { name: "Error detection and editing", detail: "Spotting grammatical errors in underlined segments, identifying the type of error (agreement, tense, word choice, redundancy), and selecting the corrected version — the proofreading skill used daily in operations and communications roles." },
];
---

<BaseLayout
  title="English Online Test for Hiring & Assessment"
  description="Run an English online test for campus and communication-role hiring in India. Covers grammar, vocabulary, comprehension, business writing, and verbal reasoning. Structured scoring, anti-cheat proctoring."
  canonicalPath="/tests/english"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav aria-label="Breadcrumb" class="border-b border-aiq-border bg-aiq-bg-raised">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-sm">
      <ol class="flex items-center gap-aiq-sm list-none m-0 p-0">
        <li><a href="/" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">Home</a></li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li><a href="/tests" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">Skill Tests</a></li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li><span class="font-mono text-aiq-xs text-aiq-fg-secondary tracking-aiq-mono uppercase" aria-current="page">English Test</span></li>
      </ol>
    </div>
  </nav>

  <section class="bg-aiq-bg-base border-b border-aiq-border">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-lg m-0">Skill Test &middot; English</p>
      <h1 class="font-serif text-aiq-3xl sm:text-aiq-hero font-normal tracking-aiq-tighter text-aiq-fg-primary leading-[1.05] mb-aiq-xl mt-0 max-w-3xl">
        English Online Test for Hiring &amp; Assessment
      </h1>
      <p class="font-sans text-aiq-lg text-aiq-fg-secondary leading-relaxed mb-aiq-2xl max-w-2xl">
        An English online test screens candidates on written communication ability — grammar accuracy, vocabulary precision, reading comprehension, and business writing clarity. For customer-facing, operations, and campus hiring roles in India, English proficiency is often the single biggest predictor of onboarding speed and communication quality on the job.
      </p>
      <div class="flex flex-wrap items-center gap-aiq-md">
        <a href="https://assessiq.in/admin/login" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white hover:bg-aiq-accent-hover transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Get started free</a>
        <a href="/contact" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill border border-aiq-border-strong text-aiq-fg-primary hover:border-aiq-accent hover:text-aiq-accent transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Talk to us</a>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="topics-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Topic breakdown</p>
      <h2 id="topics-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">What the English test covers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-aiq-lg">
        {topics.map(t => (
          <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
            <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">{t.name}</p>
            <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">{t.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-base border-b border-aiq-border" aria-labelledby="sample-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Sample question</p>
      <h2 id="sample-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">The kind of question candidates answer</h2>
      <div class="max-w-3xl">
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl mb-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md mt-0">Business writing register — mid level</p>
          <p class="font-sans text-aiq-md text-aiq-fg-primary leading-relaxed mb-aiq-lg font-medium">
            A candidate is writing a follow-up email to a client after a delayed delivery. Which sentence is most appropriate for the opening of that email?
          </p>
          <ul class="list-none m-0 p-0 flex flex-col gap-aiq-sm font-sans text-aiq-md text-aiq-fg-secondary mb-aiq-lg">
            <li>A. "Hey, just checking in about that delivery thing."</li>
            <li>B. "We are writing with regards to your query pertaining to the aforesaid delivery matter."</li>
            <li class="text-aiq-accent font-medium">C. "I wanted to follow up on the delivery scheduled for 18 May and update you on its current status." &#10003; Correct</li>
            <li>D. "You must be wondering why your order has not arrived as yet."</li>
          </ul>
          <div class="bg-aiq-bg-sunken border border-aiq-border rounded-aiq-md p-aiq-lg">
            <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Why C is correct</p>
            <p class="font-sans text-aiq-sm text-aiq-fg-secondary leading-relaxed m-0">
              A is too casual for a professional email. B is over-formal ("aforesaid," "pertaining to") and obscure. D assumes a negative client emotion and sounds defensive. C is direct, professional, and client-focused — it names the specific delivery and signals that the sender has something to say, which respects the reader's time.
            </p>
          </div>
        </div>
        <div class="bg-aiq-accent-soft border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">What this question tests</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Register calibration — the ability to choose the appropriate level of formality for the context. Many Indian candidates are taught hyper-formal English ("pertaining to," "aforesaid") that reads as unclear and old-fashioned in modern business communication. This question directly screens for that gap.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="roles-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Who should take it</p>
      <h2 id="roles-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Roles this test screens for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-aiq-lg max-w-4xl">
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Customer Success &amp; Support</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Written English quality directly affects customer satisfaction for support tickets, chat, and email. Grammar accuracy and professional register are the primary screening dimensions for these roles.</p>
        </div>
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Operations &amp; BPO</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Reading comprehension speed and accuracy matter for processing-heavy roles. Combine with an <a href="/tests/aptitude" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">aptitude test</a> for a complete ops screening pack.</p>
        </div>
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Campus Drives (All Streams)</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">English is a standard component of Indian campus placement tests across engineering and management streams. Combine with <a href="/tests/aptitude" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">aptitude</a> and <a href="/tests/logical-reasoning" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">logical reasoning</a> for a full drive pack.</p>
        </div>
      </div>
      <p class="font-sans text-aiq-sm text-aiq-fg-muted leading-relaxed mt-aiq-xl mb-0">Relevant for <a href="/solutions/campus-recruitment" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">campus recruitment</a> and <a href="/solutions/educational-institutions" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">educational institutions</a> in India.</p>
    </div>
  </section>

  <section class="bg-aiq-bg-base border-b border-aiq-border" aria-labelledby="format-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Format &amp; difficulty</p>
      <h2 id="format-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Duration, format, and difficulty levels</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-aiq-lg max-w-3xl">
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Duration</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">20–45 min</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Configurable per test</p>
        </div>
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Format</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">MCQ + Written</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Grammar + comprehension + writing</p>
        </div>
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Levels</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">Foundation — Advanced</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Basic grammar to business writing</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="faq-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">FAQ</p>
      <h2 id="faq-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Common questions about the English online test</h2>
      <div class="flex flex-col gap-aiq-xl max-w-3xl">
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">How long is an English online test for hiring?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">A focused grammar and vocabulary set runs 15–20 minutes. Adding comprehension and writing questions extends it to 30–45 minutes. Duration is configurable.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Is the English test free on AssessIQ?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">The free tier lets you run English tests and review results. Paid plans add higher volumes and advanced proctoring. See the <a href="/pricing" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">pricing page</a>.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">What is a good score on an English test for a customer-facing role?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">For customer success and support roles, comprehension and business-writing scores are more predictive than grammar MCQ performance. AssessIQ shows per-section breakdowns so you can weight sections by role requirement.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Does the English test assess spoken English?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">The test is text-based. Spoken English assessment requires a voice-recording or video interview tool. For roles where verbal communication is primary, pair the written test with a structured panel interview.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Can I use the English test for campus placement drives?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes. Combining English with aptitude and coding in a single timed session is standard for campus placement drives in India. Bulk invite and concurrent session handling support large simultaneous cohorts.</p></div>
        <div><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Is the English test suitable for screening BPO and operations roles?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes. Grammar accuracy, reading speed, and writing clarity are directly predictive of BPO and operations performance. The test can be configured to emphasise comprehension and written communication over advanced vocabulary.</p></div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-base" aria-labelledby="related-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-aiq-4xl items-start">
        <div>
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Get started</p>
          <h2 class="font-serif text-aiq-2xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-xl mt-0">Ready to screen English communication skills?</h2>
          <div class="flex flex-wrap gap-aiq-md">
            <a href="https://assessiq.in/admin/login" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white hover:bg-aiq-accent-hover transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Start free</a>
            <a href="/pricing" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill border border-aiq-border-strong text-aiq-fg-primary hover:border-aiq-accent hover:text-aiq-accent transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Pricing</a>
          </div>
        </div>
        <div>
          <p id="related-heading" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Related tests</p>
          <ul class="list-none m-0 p-0 flex flex-col gap-aiq-md">
            <li><a href="/tests/aptitude" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">Aptitude Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Pair with English for campus hiring and BPO screening.</p></li>
            <li><a href="/tests/logical-reasoning" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">Logical Reasoning Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Complete the reasoning battery for campus drives.</p></li>
            <li><a href="/tests/python" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">Python Online Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Add a technical screen for engineering campus drives.</p></li>
            <li><a href="/tests" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">All skill tests &rarr;</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
