---
// tests/java.astro — Java Online Test skill page (/tests/java)
// JSON-LD: Service + FAQPage + BreadcrumbList (separate blocks per SEO §3.6 / §15)
// NO aggregateRating, NO fabricated stats
import BaseLayout from '../../layouts/BaseLayout.astro';

const site = 'https://assessiq.in';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Java skills assessment",
  "provider": { "@type": "Organization", "name": "AssessIQ" },
  "areaServed": ["India", "Worldwide"],
  "description": "Online Java test for pre-employment screening and technical hiring. Evaluates OOP principles, Java Collections, multithreading, exception handling, and Spring fundamentals. Structured scoring for IT companies in India.",
  "url": `${site}/tests/java`
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long is a Java online test?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Java MCQ and output-prediction test typically runs 30–45 minutes. Tests that include live coding problems — writing class implementations or fixing buggy code — run 60–90 minutes. Duration is configurable by the admin."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Java test free on AssessIQ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AssessIQ has a free tier for running and reviewing assessments. Volume limits and advanced proctoring are part of paid plans. Check the pricing page for current tier limits."
      }
    },
    {
      "@type": "Question",
      "name": "What Java version does the test cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AssessIQ Java question packs focus on Java 8+ features — lambdas, streams, Optional, and the updated Collections API — alongside core language constructs that are stable across versions. Questions specify the Java version context where it matters."
      }
    },
    {
      "@type": "Question",
      "name": "Does the Java test include Spring Framework questions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, at the mid-level and senior tiers. Spring questions cover dependency injection, bean lifecycle, and Spring Boot auto-configuration. These are kept separate from the core Java question bank so admins can include or exclude framework questions depending on the role."
      }
    },
    {
      "@type": "Question",
      "name": "What score is considered good on a Java test?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shortlist thresholds depend on the seniority level and the question mix. AssessIQ shows the score distribution across your candidate cohort so you can set thresholds relative to how your actual pool performs, rather than relying on fixed pass marks."
      }
    },
    {
      "@type": "Question",
      "name": "Can I screen Java candidates in bulk for campus placement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Bulk invite via CSV, shareable test links, and concurrent session handling are available on all plans. Campus Java tests are a common use case — pairing a Java core pack with an aptitude section in a single timed session is supported."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${site}/` },
    { "@type": "ListItem", "position": 2, "name": "Skill Tests", "item": `${site}/tests` },
    { "@type": "ListItem", "position": 3, "name": "Java Test" }
  ]
};

const topics = [
  { name: "OOP principles", detail: "Classes, interfaces, abstract classes, inheritance, polymorphism, encapsulation — including when to use each and common design pitfalls." },
  { name: "Java Collections", detail: "List, Set, Map, Queue implementations; iterator patterns; time complexity trade-offs between ArrayList, LinkedList, HashMap, TreeMap, and HashSet." },
  { name: "Multithreading & concurrency", detail: "Thread lifecycle, synchronized blocks, the java.util.concurrent package (ExecutorService, Future, CountDownLatch), and common race-condition patterns." },
  { name: "Exception handling", detail: "Checked vs unchecked exceptions, custom exception hierarchies, try-with-resources for AutoCloseable, and proper exception propagation design." },
  { name: "Java 8+ features", detail: "Lambda expressions, the Stream API (filter, map, collect, reduce), Optional, method references, and default interface methods." },
  { name: "Spring fundamentals", detail: "IoC container, dependency injection (constructor vs field), Spring Boot auto-configuration, @Component/@Service/@Repository stereotypes, and bean scopes." },
];
---

<BaseLayout
  title="Java Online Test for Hiring & Assessment"
  description="Run a Java online test to screen developers in India. Covers OOP, Collections, multithreading, Java 8+ features, and Spring basics. Structured scoring, live coding, proctoring included."
  canonicalPath="/tests/java"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav aria-label="Breadcrumb" class="border-b border-aiq-border bg-aiq-bg-raised">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-sm">
      <ol class="flex items-center gap-aiq-sm list-none m-0 p-0">
        <li><a href="/" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">Home</a></li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li><a href="/tests" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">Skill Tests</a></li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li><span class="font-mono text-aiq-xs text-aiq-fg-secondary tracking-aiq-mono uppercase" aria-current="page">Java Test</span></li>
      </ol>
    </div>
  </nav>

  <section class="bg-aiq-bg-base border-b border-aiq-border">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-lg m-0">Skill Test &middot; Java</p>
      <h1 class="font-serif text-aiq-3xl sm:text-aiq-hero font-normal tracking-aiq-tighter text-aiq-fg-primary leading-[1.05] mb-aiq-xl mt-0 max-w-3xl">
        Java Online Test for Hiring &amp; Assessment
      </h1>
      <p class="font-sans text-aiq-lg text-aiq-fg-secondary leading-relaxed mb-aiq-2xl max-w-2xl">
        A Java online test evaluates a candidate's command of object-oriented design, the Collections framework, concurrency patterns, and modern Java features. It separates candidates who know Java's syntax from those who understand its memory model, threading semantics, and library idioms — the gaps that surface in code review and production incidents.
      </p>
      <div class="flex flex-wrap items-center gap-aiq-md">
        <a href="https://assessiq.in/admin/login" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white hover:bg-aiq-accent-hover transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Get started free</a>
        <a href="/contact" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill border border-aiq-border-strong text-aiq-fg-primary hover:border-aiq-accent hover:text-aiq-accent transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Talk to us</a>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="topics-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Topic breakdown</p>
      <h2 id="topics-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">
        What the Java test covers
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-aiq-lg">
        {topics.map(t => (
          <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
            <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">{t.name}</p>
            <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">{t.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-base border-b border-aiq-border" aria-labelledby="sample-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Sample question</p>
      <h2 id="sample-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">
        The kind of question candidates answer
      </h2>
      <div class="max-w-3xl">
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl mb-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md mt-0">Concurrency — mid level</p>
          <p class="font-sans text-aiq-md text-aiq-fg-primary leading-relaxed mb-aiq-lg font-medium">Which statement about the following code is correct?</p>
          <pre class="bg-aiq-bg-sunken border border-aiq-border rounded-aiq-md p-aiq-lg font-mono text-aiq-sm text-aiq-fg-primary leading-relaxed overflow-x-auto mb-aiq-lg"><code>public class Counter &#123;
    private int count = 0;

    public void increment() &#123;
        count++;
    &#125;

    public int get() &#123;
        return count;
    &#125;
&#125;</code></pre>
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Options</p>
          <ul class="list-none m-0 p-0 flex flex-col gap-aiq-sm font-sans text-aiq-md text-aiq-fg-secondary">
            <li>A. This class is thread-safe because count is a primitive.</li>
            <li class="text-aiq-accent font-medium">B. This class is NOT thread-safe; count++ is not atomic. &#10003; Correct</li>
            <li>C. Marking increment() as synchronized is unnecessary overhead.</li>
            <li>D. Using volatile on count makes increment() thread-safe.</li>
          </ul>
        </div>
        <div class="bg-aiq-accent-soft border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">What this question tests</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">
            Understanding that <code class="font-mono text-aiq-sm bg-aiq-bg-sunken px-1 rounded">count++</code> compiles to a read-modify-write sequence that is not atomic in the JVM. Distinguishing between <code class="font-mono text-aiq-sm bg-aiq-bg-sunken px-1 rounded">volatile</code> (visibility guarantee only) and <code class="font-mono text-aiq-sm bg-aiq-bg-sunken px-1 rounded">synchronized</code> or <code class="font-mono text-aiq-sm bg-aiq-bg-sunken px-1 rounded">AtomicInteger</code> (atomicity guarantee). A common production mistake in Java backend code.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="roles-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Who should take it</p>
      <h2 id="roles-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Roles this test screens for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-aiq-lg max-w-4xl">
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Java / Backend Developer</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Core screening for product and enterprise engineering teams hiring Java generalists or Spring Boot specialists.</p>
        </div>
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Android Developer</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Java fundamentals underpin Android development. Pair a Java core pack with Android-specific questions for mobile engineering roles.</p>
        </div>
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-xl">
          <p class="font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase mb-aiq-sm mt-0 font-medium">Full-Stack / API Engineer</p>
          <p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Teams building REST APIs on Spring Boot can screen for the OOP and concurrency foundations a senior engineer needs before the architecture interview.</p>
        </div>
      </div>
      <p class="font-sans text-aiq-sm text-aiq-fg-muted leading-relaxed mt-aiq-xl mb-0">Relevant for <a href="/solutions/it-hiring" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">IT &amp; technical hiring</a> and <a href="/solutions/campus-recruitment" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">campus recruitment</a> in India.</p>
    </div>
  </section>

  <section class="bg-aiq-bg-base border-b border-aiq-border" aria-labelledby="format-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Format &amp; difficulty</p>
      <h2 id="format-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Duration, format, and difficulty levels</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-aiq-lg max-w-3xl">
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Duration</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">30–90 min</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Configurable per test</p>
        </div>
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Format</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">MCQ + Live code</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Output prediction + implementation</p>
        </div>
        <div class="bg-aiq-bg-raised border border-aiq-border rounded-aiq-lg p-aiq-xl text-center">
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Levels</p>
          <p class="font-serif text-aiq-2xl font-normal text-aiq-fg-primary mb-aiq-xs mt-0">Junior — Senior</p>
          <p class="font-sans text-aiq-sm text-aiq-fg-muted m-0">Separate packs by experience tier</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-raised border-b border-aiq-border" aria-labelledby="faq-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">FAQ</p>
      <h2 id="faq-heading" class="font-serif text-aiq-3xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-3xl mt-0">Common questions about the Java online test</h2>
      <div class="flex flex-col gap-aiq-xl max-w-3xl">
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">How long is a Java online test?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">A Java MCQ and output-prediction test typically runs 30–45 minutes. Tests that include live coding problems run 60–90 minutes. Duration is configurable by the admin.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Is the Java test free on AssessIQ?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">AssessIQ has a free tier for running and reviewing assessments. Volume limits and advanced proctoring are part of paid plans. Check the <a href="/pricing" class="text-aiq-accent hover:text-aiq-accent-hover underline underline-offset-2">pricing page</a> for current tier limits.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">What Java version does the test cover?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">AssessIQ Java question packs focus on Java 8+ features — lambdas, streams, Optional, and the updated Collections API — alongside core language constructs stable across versions.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Does the Java test include Spring Framework questions?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes, at mid-level and senior tiers. Spring questions cover dependency injection, bean lifecycle, and Spring Boot auto-configuration. These are kept separate from the core Java question bank so admins can include or exclude them by role.</p></div>
        <div class="border-b border-aiq-border pb-aiq-xl"><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">What score is considered good on a Java test?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Shortlist thresholds depend on the seniority level and the question mix. AssessIQ shows the score distribution across your candidate cohort so you can set thresholds relative to how your actual pool performs.</p></div>
        <div><h3 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-sm mt-0">Can I screen Java candidates in bulk for campus placement?</h3><p class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0">Yes. Bulk invite via CSV, shareable test links, and concurrent session handling are available on all plans. Pairing a Java core pack with an aptitude section in a single timed session is supported.</p></div>
      </div>
    </div>
  </section>

  <section class="bg-aiq-bg-base" aria-labelledby="related-heading">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-aiq-4xl items-start">
        <div>
          <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Get started</p>
          <h2 class="font-serif text-aiq-2xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-xl mt-0">Ready to screen Java candidates?</h2>
          <div class="flex flex-wrap gap-aiq-md">
            <a href="https://assessiq.in/admin/login" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white hover:bg-aiq-accent-hover transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Start free</a>
            <a href="/pricing" class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill border border-aiq-border-strong text-aiq-fg-primary hover:border-aiq-accent hover:text-aiq-accent transition-colors duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2">Pricing</a>
          </div>
        </div>
        <div>
          <p id="related-heading" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-md m-0">Related tests</p>
          <ul class="list-none m-0 p-0 flex flex-col gap-aiq-md">
            <li><a href="/tests/python" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">Python Online Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Backend language screening for scripting and data roles.</p></li>
            <li><a href="/tests/sql" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">SQL Online Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Database query proficiency for full-stack and API roles.</p></li>
            <li><a href="/tests/javascript" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">JavaScript Online Test</a><p class="font-sans text-aiq-sm text-aiq-fg-muted m-0 mt-aiq-xs">Frontend and full-stack language proficiency.</p></li>
            <li><a href="/tests" class="font-sans text-aiq-md text-aiq-accent hover:text-aiq-accent-hover transition-colors">All skill tests &rarr;</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
