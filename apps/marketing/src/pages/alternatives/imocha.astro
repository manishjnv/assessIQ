  { criterion: "Pricing model",        imocha: "Contact-based (starts ~$400 in India)", assessiq: "See /pricing" },
  { criterion: "Analyst recognition",  imocha: "Everest Group PEAK Matrix 2026",        assessiq: "India-first, early stage" },
