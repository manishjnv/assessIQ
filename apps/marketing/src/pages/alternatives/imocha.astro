// JSON-LD: THREE separate blocks — Article, FAQPage, BreadcrumbList (per SEO §3.6 / §5.3)
// NO aggregateRating — omitted until real G2/Capterra reviews exist (SEO §13 hard rule)
// Fairness rule: iMocha's genuine strengths acknowledged; no disparagement (SEO §6.3)
// Research basis: imocha.io, G2 2026 reviews, Everest Group PEAK Matrix 2026, SAP India partner page — verified May 2026
import BaseLayout from '../../layouts/BaseLayout.astro';

const site = 'https://assessiq.in';
const slug = '/alternatives/imocha';
const datePublished = '2026-05-23';
const dateModified  = '2026-05-23';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best iMocha Alternatives in 2026",
  "datePublished": datePublished,
  "dateModified": dateModified,
  "author": {
    "@type": "Organization",
    "name": "AssessIQ"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AssessIQ",
    "logo": {
      "@type": "ImageObject",
      "url": `${site}/favicon.svg`
    }
  },
  "mainEntityOfPage": `${site}${slug}`,
  "description": "Looking for an iMocha alternative? See how AssessIQ compares for India-first hiring assessments — structured scoring, proctoring, and a focused hiring-stage workflow."
};

