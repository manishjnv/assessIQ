              <th class="text-left py-aiq-md pr-aiq-xl font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase font-medium w-1/3">HackerEarth</th>
              <th class="text-left py-aiq-md font-mono text-aiq-xs text-aiq-accent tracking-aiq-mono uppercase font-medium w-1/3">AssessIQ</th>
            </tr>
          </thead>
          <tbody>
            {criteria.map((row, i) => (
              <tr class={`border-b border-aiq-border ${i % 2 === 0 ? 'bg-aiq-bg-base' : 'bg-aiq-bg-raised'}`}>
                <td class="py-aiq-md pr-aiq-xl text-aiq-fg-primary font-medium">{row.criterion}</td>
                <td class="py-aiq-md pr-aiq-xl text-aiq-fg-secondary">{row.hackerearth}</td>
                <td class="py-aiq-md text-aiq-fg-secondary">{row.assessiq}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="font-sans text-aiq-sm text-aiq-fg-muted mt-aiq-lg m-0">
