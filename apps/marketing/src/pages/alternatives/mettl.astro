  { criterion: "Scoring model",           mettl: "Varies by test type",                    assessiq: "Anchor-based rubrics + scoring bands" },
  { criterion: "Pricing model",           mettl: "Contact-based / enterprise",             assessiq: "See /pricing" },
  { criterion: "Ideal scale",             mettl: "Large enterprise / mass exams",          assessiq: "SME to mid-market, bulk hiring" },
