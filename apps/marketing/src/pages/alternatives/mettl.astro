      "@type": "Question",
      "name": "When should I choose AssessIQ over Mercer Mettl?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AssessIQ is likely a better fit if you are: (a) a growing Indian IT company or staffing team that wants structured, rubric-based hiring assessments without an enterprise contract; (b) prioritising per-answer scoring rationale and an admin-friendly dashboard over broad psychometric instrument libraries; or (c) running technical hiring at volumes where a simpler, focused platform is more practical than a large exam-management system."
      }
    }
  ]
};

// BreadcrumbList JSON-LD (§15 — last item has NO `item` URL per spec)
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
