  "@type": "Article",
  "headline": "Best Mercer Mettl Alternatives in 2026",
  "datePublished": datePublished,
  "dateModified": dateModified,
  "author": {
    "@type": "Organization",
    "name": "AssessIQ"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AssessIQ",
    "logo": {
      "@type": "ImageObject",
      "url": `${site}/favicon.svg`
    }
  },
  "mainEntityOfPage": `${site}${slug}`,
  "description": "Looking for a Mercer Mettl alternative? See how AssessIQ compares for India-first hiring and assessment — structured scoring, proctoring, and auditable decisions."
};

// FAQPage JSON-LD — mirrors the visible FAQ section verbatim (SEO §15 hard rule)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
