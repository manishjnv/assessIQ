const slug = '/alternatives/amcat';
const datePublished = '2026-05-23';
const dateModified  = '2026-05-23';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best AMCAT Alternatives in 2026",
  "datePublished": datePublished,
  "dateModified": dateModified,
  "author": {
    "@type": "Organization",
    "name": "AssessIQ"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AssessIQ",
    "logo": {
      "@type": "ImageObject",
      "url": `${site}/favicon.svg`
    }
  },
  "mainEntityOfPage": `${site}${slug}`,
  "description": "Looking for an AMCAT alternative? See how AssessIQ compares for India campus and fresher hiring — custom branded assessments, structured scoring, and full control of your hiring process."
};

const faqSchema = {
