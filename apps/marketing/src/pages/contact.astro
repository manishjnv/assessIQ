---
// contact.astro — Contact page
// JSON-LD: BreadcrumbList (Home › Contact) per SEO §3.6 / §15 template
// Form: static mailto — no backend yet. TODO: wire to a real form endpoint.
import BaseLayout from '../layouts/BaseLayout.astro';

const site = 'https://assessiq.in';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": `${site}/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Contact"
      // NOTE: no "item" on current/last breadcrumb per SEO §15 spec
    }
  ]
};
---

<BaseLayout
  title="Contact AssessIQ"
  description="Get in touch with the AssessIQ team. We work with IT companies, campus recruitment teams, and educational institutions across India. Reach us at connect@assessiq.in."
  canonicalPath="/contact"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb nav — visible, matches JSON-LD (SEO §3.8) -->
  <nav aria-label="Breadcrumb" class="border-b border-aiq-border bg-aiq-bg-raised">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-sm">
      <ol class="flex items-center gap-aiq-sm list-none m-0 p-0">
        <li>
          <a href="/" class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase hover:text-aiq-fg-secondary transition-colors">
            Home
          </a>
        </li>
        <li aria-hidden="true" class="font-mono text-aiq-xs text-aiq-fg-muted">&rsaquo;</li>
        <li>
          <span class="font-mono text-aiq-xs text-aiq-fg-secondary tracking-aiq-mono uppercase" aria-current="page">
            Contact
          </span>
        </li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-aiq-bg-base border-b border-aiq-border">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-lg m-0">Contact</p>
      <h1 class="font-serif text-aiq-3xl sm:text-[44px] font-normal tracking-aiq-tighter text-aiq-fg-primary leading-[1.05] mb-aiq-xl mt-0">
        Let's talk about your assessment needs.
      </h1>
      <p class="font-sans text-aiq-lg text-aiq-fg-secondary leading-relaxed m-0 max-w-2xl">
        Whether you're evaluating AssessIQ for technical hiring, campus recruitment, or institutional exams — we'd like to understand your context before recommending anything.
      </p>
    </div>
  </section>

  <!-- Contact content -->
  <section class="bg-aiq-bg-raised">
    <div class="max-w-6xl mx-auto px-aiq-xl py-aiq-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-aiq-4xl items-start">

        <!-- Direct contact info -->
        <div>
          <h2 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-xl mt-0">
            Get in touch directly.
          </h2>

          <div class="flex flex-col gap-aiq-xl">
            <div>
              <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Email</p>
              <a
                href="mailto:connect@assessiq.in"
                class="font-sans text-aiq-lg text-aiq-accent hover:text-aiq-accent-hover transition-colors
                       focus:outline-none focus-visible:underline"
              >
                connect@assessiq.in
              </a>
            </div>

            <div>
              <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-aiq-mono uppercase mb-aiq-sm mt-0">Best for</p>
              <ul class="font-sans text-aiq-md text-aiq-fg-secondary leading-relaxed m-0 p-0 list-none flex flex-col gap-aiq-sm">
                <li class="flex items-start gap-aiq-sm">
                  <span class="text-aiq-accent mt-0.5 flex-shrink-0" aria-hidden="true">&#10003;</span>
                  Demo requests and pricing enquiries
                </li>
                <li class="flex items-start gap-aiq-sm">
                  <span class="text-aiq-accent mt-0.5 flex-shrink-0" aria-hidden="true">&#10003;</span>
                  Campus bulk-hire assessment setup
                </li>
                <li class="flex items-start gap-aiq-sm">
                  <span class="text-aiq-accent mt-0.5 flex-shrink-0" aria-hidden="true">&#10003;</span>
                  Institution onboarding and certification programmes
                </li>
                <li class="flex items-start gap-aiq-sm">
                  <span class="text-aiq-accent mt-0.5 flex-shrink-0" aria-hidden="true">&#10003;</span>
                  Partnership and integration enquiries
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Static contact form — mailto action, no backend yet -->
        <!-- TODO: real data — wire to a form backend (Formspark / custom endpoint) when ready -->
        <div class="bg-aiq-bg-base border border-aiq-border rounded-aiq-lg p-aiq-2xl">
          <h2 class="font-serif text-aiq-xl font-normal tracking-aiq-tight text-aiq-fg-primary mb-aiq-xl mt-0">
            Send us a note.
          </h2>

          <form
            id="contact-form"
            class="flex flex-col gap-aiq-lg"
            aria-label="Contact form"
          >
            <!-- Honeypot — hidden from real users; bots fill it in.
                 Submission is silently dropped server-side when non-empty. -->
            <input
              type="text"
              name="company_website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden"
            />

            <div class="flex flex-col gap-aiq-sm">
              <label for="contact-name" class="font-sans text-aiq-sm font-medium text-aiq-fg-primary">
                Your name
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                autocomplete="name"
                required
                placeholder="e.g. Priya Sharma"
                class="font-sans text-aiq-md text-aiq-fg-primary placeholder:text-aiq-fg-muted
                       border border-aiq-border-strong rounded-aiq-md px-4 py-3
                       focus:outline-none focus:border-aiq-accent focus:shadow-[0_0_0_4px_#eef3fd]
                       transition-colors bg-aiq-bg-base"
              />
            </div>

            <div class="flex flex-col gap-aiq-sm">
              <label for="contact-email" class="font-sans text-aiq-sm font-medium text-aiq-fg-primary">
                Work email
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                autocomplete="email"
                required
                placeholder="you@company.in"
                class="font-sans text-aiq-md text-aiq-fg-primary placeholder:text-aiq-fg-muted
                       border border-aiq-border-strong rounded-aiq-md px-4 py-3
                       focus:outline-none focus:border-aiq-accent focus:shadow-[0_0_0_4px_#eef3fd]
                       transition-colors bg-aiq-bg-base"
              />
            </div>

            <div class="flex flex-col gap-aiq-sm">
              <label for="contact-message" class="font-sans text-aiq-sm font-medium text-aiq-fg-primary">
                How can we help?
              </label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                required
                placeholder="Tell us about your team size, role types, or assessment goals."
                class="font-sans text-aiq-md text-aiq-fg-primary placeholder:text-aiq-fg-muted
                       border border-aiq-border-strong rounded-aiq-md px-4 py-3 resize-y
                       focus:outline-none focus:border-aiq-accent focus:shadow-[0_0_0_4px_#eef3fd]
                       transition-colors bg-aiq-bg-base"
              ></textarea>
            </div>

            <!-- Cloudflare Turnstile — bot check; the token is verified server-side in /api/contact. -->
            <div class="cf-turnstile" data-sitekey="0x4AAAAAADVMWHe1bQPyzyZJ" data-theme="light"></div>

            <button
              type="submit"
              class="font-sans text-aiq-md font-medium px-6 py-3 rounded-aiq-pill bg-aiq-accent text-white
                     hover:bg-aiq-accent-hover transition-colors duration-150 self-start
                     focus:outline-none focus-visible:ring-2 focus-visible:ring-aiq-accent focus-visible:ring-offset-2"
            >
              Send message
            </button>

            <p id="contact-status" role="status" aria-live="polite" class="font-sans text-aiq-sm m-0" style="min-height:1.25rem"></p>

            <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-[0.04em] m-0">
              We'll reply from <strong class="font-medium text-aiq-fg-secondary">connect@assessiq.in</strong>.
            </p>
            <p class="font-mono text-aiq-xs text-aiq-fg-muted tracking-[0.04em] m-0">
              We'll use your details only to reply to your enquiry. See our <a href="/privacy" class="text-aiq-accent underline">Privacy Policy</a>.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<!-- Cloudflare Turnstile API — renders the widget; is:inline so Astro emits it verbatim. -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<script>
  const form     = document.getElementById('contact-form') as HTMLFormElement | null;
  const nameEl   = document.getElementById('contact-name') as HTMLInputElement | null;
  const emailEl  = document.getElementById('contact-email') as HTMLInputElement | null;
  const msgEl    = document.getElementById('contact-message') as HTMLTextAreaElement | null;
  const honeypot = form?.querySelector<HTMLInputElement>('input[name="company_website"]') ?? null;
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]') ?? null;
  const status   = document.getElementById('contact-status') as HTMLElement | null;

  if (form && nameEl && emailEl && msgEl && status && submitBtn) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      const name    = nameEl.value.trim();
      const email   = emailEl.value.trim();
      const message = msgEl.value.trim();
      const company_website = honeypot?.value ?? '';

      // Cloudflare Turnstile injects this hidden input once the challenge is solved.
      const tokenEl = form.querySelector('input[name="cf-turnstile-response"]') as HTMLInputElement | null;
      const cf_turnstile_response = tokenEl?.value ?? '';
      if (!cf_turnstile_response) {
        status.textContent = 'Please complete the verification and try again.';
        status.style.color = 'var(--aiq-color-danger, #c0392b)';
        return;
      }

      submitBtn.disabled = true;
      status.textContent = 'Sending…';
      status.style.color = '';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message, company_website, cf_turnstile_response }),
        });

        if (res.ok) {
          status.textContent = "Thanks — we’ve got your message and will be in touch soon.";
          status.style.color = 'var(--aiq-color-fg-secondary, #555)';
          form.reset();
          submitBtn.disabled = false;
        } else {
          status.textContent = 'Something went wrong. Please email connect@assessiq.in directly.';
          status.style.color = 'var(--aiq-color-danger, #c0392b)';
          submitBtn.disabled = false;
        }
      } catch {
        status.textContent = 'Something went wrong. Please email connect@assessiq.in directly.';
        status.style.color = 'var(--aiq-color-danger, #c0392b)';
        submitBtn.disabled = false;
      } finally {
        // Turnstile tokens are single-use — reset so a retry gets a fresh one.
        (window as any).turnstile?.reset();
      }
    });
  }
</script>
