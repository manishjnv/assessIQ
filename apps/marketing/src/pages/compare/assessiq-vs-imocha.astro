  description="AssessIQ vs iMocha: 2026 comparison — India focus, skills intelligence, coding assessments, proctoring, workforce analytics, and which platform fits your needs."
  canonicalPath="/compare/assessiq-vs-imocha"
  ogType="article"
>
  <!-- JSON-LD: Article (separate block per §3.6) -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <!-- JSON-LD: FAQPage (separate block per §3.6) -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <!-- JSON-LD: BreadcrumbList (separate block per §3.6) -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb nav — visible, matches JSON-LD (SEO §3.8) -->
