---
// compare/assessiq-vs-imocha.astro — /compare/assessiq-vs-imocha
// JSON-LD: THREE separate blocks — Article, FAQPage, BreadcrumbList (per SEO §3.6 / §5.3 / §15)
// NO aggregateRating — omitted until real G2/Capterra reviews exist (SEO §13 hard rule)
// NO specific price claims for either platform (anti-fabrication rule)
// Competitor facts sourced from publicly verifiable information (2025-2026)
import BaseLayout from '../../layouts/BaseLayout.astro';

const site = 'https://assessiq.in';

// Article JSON-LD (§15 template — comparison pages use Article)
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "AssessIQ vs iMocha: Complete 2026 Comparison",
  "datePublished": "2026-05-23",
  "dateModified": "2026-05-23",
  "author": {
    "@type": "Organization",
    "name": "AssessIQ",
    "url": `${site}/`
  },
  "publisher": {
    "@type": "Organization",
    "name": "AssessIQ",
    "logo": {
      "@type": "ImageObject",
      "url": `${site}/favicon.svg`
    }
  },
  "mainEntityOfPage": `${site}/compare/assessiq-vs-imocha`,
  "description": "An honest, side-by-side comparison of AssessIQ and iMocha across India focus, skills intelligence, pre-employment screening, proctoring, enterprise workforce analytics, and ideal customer — updated May 2026."
};

// FAQPage JSON-LD — mirrors the visible FAQ section verbatim (SEO §15 hard rule)
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is iMocha?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iMocha is a skills assessment and Skills Intelligence Cloud platform that serves enterprise customers globally. It offers 3,000+ ready-to-use skill assessments, AI-powered proctoring, and a workforce analytics layer that maps skills across the employee lifecycle — from pre-employment screening to upskilling and internal mobility. iMocha is recognized as a major player in the IDC MarketScape for Worldwide Talent Intelligence (2026)."
      }
    },
    {
      "@type": "Question",
      "name": "How does AssessIQ differ from iMocha?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iMocha's strength is its Skills Intelligence Cloud — AI-powered workforce analytics that map skills gaps across an organization's existing talent pool, not just candidate screening. AssessIQ is focused on the hiring and institutional assessment use case: structured coding tests, rubric-based scoring, proctoring with per-attempt audit logs, and a simple admin workflow for Indian IT companies and educational institutions. If your primary need is workforce skills mapping and talent intelligence at enterprise scale, iMocha is purpose-built for that. If your primary need is structured pre-interview screening with scoring rationale, AssessIQ is the more focused option."
      }
    },
    {
      "@type": "Question",
      "name": "Does iMocha support coding assessments?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iMocha includes coding and project-based assessments as part of its 3,000+ assessment library. AssessIQ's coding environment runs submissions against hidden test cases with real-time pass/fail results and execution time visible to the admin. Both platforms support coding evaluation; the depth and focus of the coding experience differs — iMocha is part of a broader skill assessment and intelligence platform, while AssessIQ centers the coding test experience as a core hiring workflow."
      }
    },
    {
      "@type": "Question",
      "name": "Is iMocha designed for Indian companies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iMocha operates across India/APAC, North America, and UK/EMEA — it serves 500+ enterprise customers across three continents. AssessIQ is built India-first: calibrated question packs for Indian IT role stacks, local data residency, and pricing designed for Indian team sizes and hiring volumes. Both serve Indian customers; AssessIQ's entire design is oriented around the India B2B hiring context."
      }
    },
    {
      "@type": "Question",
      "name": "What is the iMocha Skills Intelligence Cloud?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iMocha's Skills Intelligence Cloud is an enterprise workforce analytics layer that provides AI-powered visibility into an organization's skill inventory — mapping 30,000+ skills across roles, inferring skills gaps, matching talent to open positions, and tracking upskilling progress. It extends beyond candidate screening into the full employee lifecycle: L&D, internal mobility, and workforce planning. AssessIQ does not offer this workforce intelligence layer — it focuses on structured pre-employment assessment and institutional exam delivery."
      }
    },
    {
      "@type": "Question",
      "name": "Can I try AssessIQ for free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. AssessIQ has a free starting point — create an account and run assessments without a credit card. This makes it straightforward to evaluate the platform against your real hiring workflow before committing."
      }
    }
  ]
};

// BreadcrumbList JSON-LD (§15 — last item has NO `item` URL per spec)
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": `${site}/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Compare",
      "item": `${site}/compare`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "AssessIQ vs iMocha"
      // NOTE: no "item" on current/last breadcrumb per SEO §15 spec
    }
  ]
};

// Comparison table rows — neutral criteria, honest entries, no absolute "lacks X" claims
const tableRows = [
  {
    criterion: "India focus",
    assessiq: "Built India-first — calibrated question packs for Indian IT role stacks, local data residency, pricing designed for Indian teams",
    imocha: "Operates across India/APAC, NA, and UK/EMEA; serves enterprise customers globally across 70+ countries"
  },
  {
    criterion: "Proctoring",
    assessiq: "Tab-switch detection, full-screen enforcement, webcam monitoring, copy-paste restriction, timestamped event log per attempt",
    imocha: "AI-enabled proctoring tools included; secure remote assessment delivery across enterprise exam programs"
  },
  {
    criterion: "Question / assessment types",
    assessiq: "Coding (live execution + test cases), MCQ, output prediction, aptitude, logical reasoning — curated for Indian IT hiring",
    imocha: "3,000+ ready-to-use assessments including coding, cognitive, situational, and project-based; 10,000+ assessments per some published figures"
  },
  {
    criterion: "Code evaluation",
    assessiq: "Browser-based coding environment; submissions run against hidden test cases; pass/fail count + execution time visible to admin",
    imocha: "Coding assessments and project-based assessments available; real-world challenge evaluation as part of broader skills platform"
  },
  {
    criterion: "Skills intelligence",
    assessiq: "Structured scoring per role/test; admin dashboard for cohort analytics; focused on pre-employment assessment output",
    imocha: "Skills Intelligence Cloud — AI maps 30,000+ skills across roles, infers gaps, supports internal mobility and workforce planning at enterprise scale"
  },
  {
    criterion: "Workforce analytics",
    assessiq: "Per-candidate and cohort-level reports; CSV/PDF export; focused on hiring decision support",
    imocha: "Enterprise workforce analytics across the full talent lifecycle — hiring, L&D, upskilling, internal mobility, workforce planning"
  },
  {
    criterion: "Structured scoring",
    assessiq: "Anchor-based rubrics and scoring bands per question; per-answer rationale visible to reviewer",
    imocha: "Scoring across varied assessment types; analytics dashboard; industry benchmarking — check vendor for rubric-level detail"
  },
  {
    criterion: "Integrations",
    assessiq: "Admin dashboard, CSV export, PDF reports; ATS integrations — varies by plan (check current docs)",
    imocha: "SAP and major HRMS/ATS integrations; enterprise integration catalog; Skills Intelligence Cloud connects to existing HR infrastructure"
  },
  {
    criterion: "Deployment / scale",
    assessiq: "Cloud SaaS; bulk invite via CSV or shareable link; no per-seat cap on concurrent sessions",
    imocha: "Cloud SaaS; enterprise-scale deployment across 500+ customers in 70+ countries; purpose-built for large organizations"
  },
  {
    criterion: "Ideal customer",
    assessiq: "Indian IT companies, campus teams, and educational institutions needing structured, auditable pre-employment assessment with transparent scoring",
    imocha: "Enterprises requiring skills intelligence across the full talent lifecycle — pre-employment through L&D and workforce planning — especially at Fortune 500 scale"
  }
];

const faqs = [
  {
    q: "What is iMocha?",
    a: "iMocha is a skills assessment and Skills Intelligence Cloud platform that serves enterprise customers globally. It offers 3,000+ ready-to-use skill assessments, AI-powered proctoring, and a workforce analytics layer that maps skills across the employee lifecycle — from pre-employment screening to upskilling and internal mobility. iMocha is recognized as a major player in the IDC MarketScape for Worldwide Talent Intelligence (2026)."
  },
  {
    q: "How does AssessIQ differ from iMocha?",
    a: "iMocha's strength is its Skills Intelligence Cloud — AI-powered workforce analytics that map skills gaps across an organization's existing talent pool, not just candidate screening. AssessIQ is focused on the hiring and institutional assessment use case: structured coding tests, rubric-based scoring, proctoring with per-attempt audit logs, and a simple admin workflow for Indian IT companies and educational institutions. If your primary need is workforce skills mapping and talent intelligence at enterprise scale, iMocha is purpose-built for that. If your primary need is structured pre-interview screening with scoring rationale, AssessIQ is the more focused option."
  },
  {
    q: "Does iMocha support coding assessments?",
    a: "iMocha includes coding and project-based assessments as part of its 3,000+ assessment library. AssessIQ's coding environment runs submissions against hidden test cases with real-time pass/fail results and execution time visible to the admin. Both platforms support coding evaluation; the depth and focus of the coding experience differs — iMocha is part of a broader skill assessment and intelligence platform, while AssessIQ centers the coding test experience as a core hiring workflow."
  },
  {
    q: "Is iMocha designed for Indian companies?",
    a: "iMocha operates across India/APAC, North America, and UK/EMEA — it serves 500+ enterprise customers across three continents. AssessIQ is built India-first: calibrated question packs for Indian IT role stacks, local data residency, and pricing designed for Indian team sizes and hiring volumes. Both serve Indian customers; AssessIQ's entire design is oriented around the India B2B hiring context."
  },
  {
    q: "What is the iMocha Skills Intelligence Cloud?",
    a: "iMocha's Skills Intelligence Cloud is an enterprise workforce analytics layer that provides AI-powered visibility into an organization's skill inventory — mapping 30,000+ skills across roles, inferring skills gaps, matching talent to open positions, and tracking upskilling progress. It extends beyond candidate screening into the full employee lifecycle: L&D, internal mobility, and workforce planning. AssessIQ does not offer this workforce intelligence layer — it focuses on structured pre-employment assessment and institutional exam delivery."
  },
  {
    q: "Can I try AssessIQ for free?",
    a: "Yes. AssessIQ has a free starting point — create an account and run assessments without a credit card. This makes it straightforward to evaluate the platform against your real hiring workflow before committing."
  }
