{
  "name": "assessiq",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @assessiq/web e2e",
    "test:watch": "vitest",
    "help:seed:regen": "tsx tools/generate-help-seed.ts",
    "lint:rls": "tsx tools/lint-rls-policies.ts",
    "lint:ambient-ai": "tsx modules/07-ai-grading/ci/lint-no-ambient-claude.ts",
    "lint:ambient-ai:self-test": "tsx modules/07-ai-grading/ci/lint-no-ambient-claude.ts --self-test",
    "lint:edge-routing": "tsx tools/lint-edge-routing.ts",
    "lint:edge-routing:self-test": "tsx tools/lint-edge-routing.ts --self-test",
    "lint:cross-module-deps": "tsx tools/lint-cross-module-deps.ts",
    "lint:cross-module-deps:self-test": "tsx tools/lint-cross-module-deps.ts --self-test",
    "lint:deploy-procedure": "tsx tools/lint-deploy-procedure.ts",
    "lint:deploy-procedure:self-test": "tsx tools/lint-deploy-procedure.ts --self-test",
    "aiq:eval:run": "tsx modules/07-ai-grading/eval/cli.ts run",
    "aiq:eval:compare": "tsx modules/07-ai-grading/eval/cli.ts compare",
    "aiq:eval:bless": "tsx modules/07-ai-grading/eval/cli.ts bless",
    "eval:goldens": "pnpm -C modules/07-ai-grading exec tsx eval/cli-typed.ts score-goldens",
    "eval:goldens-strict": "pnpm -C modules/07-ai-grading exec tsx eval/cli-typed.ts score-goldens --strict",
    "eval:fixtures-check": "tsx tools/extract-eval-fixtures.ts --dry-run"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "uuidv7": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@assessiq/core": "workspace:*",
    "@assessiq/tenancy": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.13.0",
    "pino-pretty": "^11.0.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.0",
    "yaml": "^2.4.0"
  }
}
