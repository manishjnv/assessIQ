{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["react", "react-dom", "node"],
    "rootDir": "../.."
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
