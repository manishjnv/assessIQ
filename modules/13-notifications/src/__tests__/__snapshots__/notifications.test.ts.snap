// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`template snapshots — invitation_candidate > HTML renders to a stable snapshot 1`] = `
"<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<!-- i18n: page title not yet externalized -->
<title>Assessment invitation</title>
</head>
<body style="margin:0;padding:0;background:#f5f5f5;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f5f5;padding:40px 0">
<tr><td align="center">
<table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e8e8e8">
<!-- Header — white, editorial wordmark -->
<tr><td style="background:#ffffff;padding:24px 40px;border-bottom:1px solid #e8e8e8">
  <!-- i18n: brand wordmark (fixed string, not yet externalized) -->
  <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:18px;font-weight:400;color:#1a1a1a;letter-spacing:-0.01em">AssessIQ</p>
</td></tr>
<!-- Body -->
<tr><td style="padding:40px">
  <!-- i18n: greeting not yet externalized -->
  <p style="margin:0 0 16px;font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:400;color:#1a1a1a;letter-spacing:-0.01em">Hi Alice Patel,</p>
  <!-- i18n: body copy not yet externalized -->
  <p style="margin:0 0 32px;font-size:15px;color:#5f6368;line-height:1.6">
    You have been invited to take <strong style="color:#1a1a1a">SOC L1 Skills Assessment</strong> on Wipro.
  </p>
  <!-- CTA — pill button, brand accent #1a73e8 = oklch(0.58 0.17 258) -->
  <!-- i18n: CTA label not yet externalized -->
  <a href="https://assessiq.test/take/tok_snapshot_test"
     style="display:inline-block;background:#1a73e8;color:#ffffff;padding:12px 28px;border-radius:999px;text-decoration:none;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:500;letter-spacing:-0.005em">
    Start your assessment
  </a>
  <!-- i18n: expiry notice not yet externalized -->
  <p style="margin:32px 0 0;font-size:13px;color:#9aa0a6;line-height:1.6">
    This invitation expires on <strong style="color:#5f6368">2026-07-01T00:00:00Z</strong>.
    If you did not expect this email, you can ignore it.
  </p>
</td></tr>
<!-- Footer -->
<tr><td style="background:#f5f5f5;padding:20px 40px;border-top:1px solid #e8e8e8">
  <!-- i18n: footer copy not yet externalized -->
  <p style="margin:0;font-size:11px;color:#9aa0a6;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif">
    &copy; AssessIQ &middot; All rights reserved.
  </p>
</td></tr>
</table>
</td></tr>
</table>
</body>
</html>
"
`;

exports[`template snapshots — invitation_candidate > text renders to a stable snapshot 1`] = `"You've been invited to take "SOC L1 Skills Assessment" on AssessIQ"`;

exports[`template snapshots — invitation_candidate > text renders to a stable snapshot 2`] = `
"Hi Alice Patel,

You have been invited to take SOC L1 Skills Assessment on Wipro.

Start your assessment:
https://assessiq.test/take/tok_snapshot_test

This invitation expires on 2026-07-01T00:00:00Z.
If you did not expect this email, you can ignore it.

— AssessIQ
"
`;
