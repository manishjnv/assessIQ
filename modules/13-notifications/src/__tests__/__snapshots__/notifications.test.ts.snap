// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`template snapshots — invitation_candidate > HTML renders to a stable snapshot 1`] = `
"<!-- Composes kit partials (Email Kit Port E2a). Diverges from kit/emails/templates-1.jsx <Invite> only where docs/13-email-system.md §4 records. -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="color-scheme" content="light only">
  <meta name="supported-color-schemes" content="light only">
  <title>Assessment invitation</title>
</head>
<body style="margin:0;padding:0;background:#f1efea;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;color:#0a0a0b;font-size:15px;line-height:1.55;letter-spacing:-0.005em;-webkit-font-smoothing:antialiased">
  <div style="display:none;font-size:1px;line-height:1px;color:#fefefe;max-height:0;max-width:0;opacity:0;overflow:hidden;mso-hide:all">
    You&#x27;ve been invited to take SOC L1 Skills Assessment on AssessIQ.&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;&#8199;&#65279;
  </div>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f1efea">
    <tr>
      <td align="center" style="padding:32px 24px 40px">
        <table role="presentation" width="640" cellpadding="0" cellspacing="0" border="0" style="width:640px;max-width:640px;background:#ffffff;border:1px solid #e4e4e7;border-radius:14px;overflow:hidden">
          
            <!-- A3 email-header — wordmark left, optional eyebrow right -->
            <tr>
              <td style="padding:22px 36px;border-bottom:1px solid #e4e4e7;background:#ffffff">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="font-family:Georgia,'Times New Roman',serif;font-size:18px;font-weight:400;color:#0a0a0b;letter-spacing:-0.01em">
                      AssessIQ
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          
          <!-- A4 email-body — generous side padding -->
          <tr>
            <td style="padding:36px 40px;background:#ffffff">
              
                  <!-- A5 email-lede-editorial (30px H1) -->
                  <p style="margin:0 0 14px;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:11px;font-weight:500;color:#1a73e8;text-transform:uppercase;letter-spacing:0.08em">INVITATION</p>
                  <h1 style="margin:0 0 14px;font-family:Georgia,'Times New Roman',serif;font-size:30px;font-weight:500;color:#0a0a0b;letter-spacing:-0.02em;line-height:1.15">You&#x27;ve been invited.</h1>
                  <p style="margin:0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:17px;color:#3f3f46;line-height:1.55">Hi Alice Patel, an AssessIQ assessment is waiting for you. The details are below.</p>
              
                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-top:28px">
                    <tr><td><!-- A7 email-meta-card — bordered key/value pair list -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e4e4e7;border-radius:12px;border-collapse:separate">
                <tr>
                  <td style="padding:14px 20px;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:10px;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;width:110px;vertical-align:middle;white-space:nowrap">
                    Assessment
                  </td>
                  <td style="padding:14px 20px 14px 0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;color:#0a0a0b;vertical-align:middle">
                    <strong>SOC L1 Skills Assessment</strong>
                  </td>
                </tr>
                <tr>
                  <td style="padding:14px 20px;border-top:1px solid #e4e4e7;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:10px;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;width:110px;vertical-align:middle;white-space:nowrap">
                    Company
                  </td>
                  <td style="padding:14px 20px 14px 0;border-top:1px solid #e4e4e7;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;color:#0a0a0b;vertical-align:middle">
                    Wipro
                  </td>
                </tr>
                <tr>
                  <td style="padding:14px 20px;border-top:1px solid #e4e4e7;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:10px;color:#71717a;text-transform:uppercase;letter-spacing:0.08em;width:110px;vertical-align:middle;white-space:nowrap">
                    Expires
                  </td>
                  <td style="padding:14px 20px 14px 0;border-top:1px solid #e4e4e7;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;color:#0a0a0b;vertical-align:middle">
                    2026-07-01T00:00:00Z
                  </td>
                </tr>
              </table>
              </td></tr>
                  </table>
              
                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top:32px">
                    <tr><td><!-- A6 email-cta — pill button with MSO/VML Outlook fallback -->
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word"
                href="https://assessiq.test/take/tok_snapshot_test"
                style="height:46px;v-text-anchor:middle;width:210px;"
                arcsize="50%" stroke="f" fillcolor="#1a73e8">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:'Helvetica Neue',Arial,sans-serif;font-size:14px;font-weight:500;letter-spacing:-0.005em">
                  Start your assessment
                </center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-->
              <a href="https://assessiq.test/take/tok_snapshot_test"
                style="display:inline-block;background:#1a73e8;color:#ffffff;padding:14px 28px;border-radius:999px;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:14px;font-weight:500;letter-spacing:-0.005em;text-decoration:none;mso-hide:all">
                Start your assessment
              </a>
              <!--<![endif]-->
              </td></tr>
                  </table>
              
                  <p style="margin:32px 0 0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:13px;color:#71717a;line-height:1.55">
                    This invitation expires on <strong style="color:#3f3f46">2026-07-01T00:00:00Z</strong>. If you did not expect this email, you can safely ignore it.
                  </p>
              
            </td>
          </tr>
          
            <!-- A9a email-footer-transactional — brand mark + reason + address + © -->
            <tr>
              <td style="padding:28px 40px 32px;background:#fafafa;border-top:1px solid #e4e4e7">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding-bottom:14px;font-family:Georgia,'Times New Roman',serif;font-size:14px;font-weight:500;color:#0a0a0b;letter-spacing:-0.01em">
                      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#1a73e8;vertical-align:middle;margin-right:10px"></span>
                      AssessIQ
                    </td>
                  </tr>
                  <tr>
                    <td style="padding-bottom:18px;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;font-size:12px;color:#3f3f46;line-height:1.55;max-width:460px">
                      You&#x27;re receiving this because an AssessIQ admin invited you to take an assessment.
                    </td>
                  </tr>
                  <tr>
                    <td style="border-top:1px solid #e4e4e7;padding-top:16px;font-family:'SF Mono',Menlo,Consolas,monospace;font-size:10px;color:#71717a;text-transform:uppercase;letter-spacing:0.08em">
                      AssessIQ &middot; Bangalore 560068, India &middot; &copy; 2026
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
"
`;

exports[`template snapshots — invitation_candidate > text renders to a stable snapshot 1`] = `"You've been invited to take SOC L1 Skills Assessment on AssessIQ"`;

exports[`template snapshots — invitation_candidate > text renders to a stable snapshot 2`] = `
"Hi Alice Patel,

You have been invited to take SOC L1 Skills Assessment on Wipro.

Start your assessment:
https://assessiq.test/take/tok_snapshot_test

This invitation expires on 2026-07-01T00:00:00Z.
If you did not expect this email, you can ignore it.

— The AssessIQ team
AssessIQ · Bangalore 560068, India · © 2026
"
`;
