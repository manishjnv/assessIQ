{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "react", "react-dom"]
  },
  "include": ["src/**/*", "components/**/*"],
  "exclude": ["dist", "node_modules"]
}
