# Per-Dockerfile dockerignore for assessiq-frontend.
# OVERRIDES the repo-root .dockerignore (BuildKit `<dockerfile>.dockerignore`
# semantics — when present, this file is used INSTEAD of, not merged with,
# the root .dockerignore). The root .dockerignore excludes apps/web,
# apps/storybook, and modules/17-ui-system to keep the api build context
# small; the frontend NEEDS apps/web + modules/17-ui-system, so we maintain
# a separate exclude list here.

# Node + build outputs
node_modules
**/node_modules
**/dist
**/.turbo
**/coverage

# Git + IDE
.git
.github
.vscode
.idea
.claude

# Env + secrets — never bake into images
.env
.env.*
!.env.example
secrets/

# Tests + dev fixtures (the runtime image ships production code only)
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
vitest.setup.ts
**/vitest.config.ts

# Apps NOT in the @assessiq/web closure
apps/api
apps/storybook

# Modules NOT in the @assessiq/web closure.
# Phase 1 G1.D added: @assessiq/web depends on @assessiq/candidate-ui (new) +
# @assessiq/help-system (existing). help-system depends on @assessiq/{core,
# tenancy,ui-system}. So the closure is now:
#   apps/web → @assessiq/{ui-system, candidate-ui, help-system}
#                → @assessiq/{core, tenancy, ui-system}
# i.e. modules/{00-core, 02-tenancy, 11-candidate-ui, 16-help-system, 17-ui-system}.
# Everything else under modules/ is server-side and excluded here.
modules/01-auth
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/03-users
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/04-question-bank
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/05-assessment-lifecycle
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/06-attempt-engine
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/07-ai-grading
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/08-rubric-engine
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/09-scoring
# UNEXCLUDED for G2.C (admin-dashboard transitive closure): modules/10-admin-dashboard
modules/12-embed-sdk
modules/13-notifications
modules/14-audit-log
modules/15-analytics

# Operational state
data/
infra/postgres/init/*.local.sql
*.log
**/*.log
infra/logrotate.d/

# Editor + OS scratch
.DS_Store
Thumbs.db
*.swp
.editorconfig

# Stash / backup files
*.bak
*.bak.*
*.orig

# Markdown docs are not consumed by the build.
docs/
modules/**/SKILL.md
PROJECT_BRAIN.md
RCA_LOG.md
README.md
