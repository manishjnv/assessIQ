# ---- Domain ----
ASSESSIQ_BASE_URL=https://assessiq.automateedge.cloud
NODE_ENV=development

# ---- Observability ----
LOG_LEVEL=info
SENTRY_DSN=

# ---- Database (PostgreSQL 16) ----
# For local dev, point at a local Postgres or the Docker service.
# For production, the password is read from Docker secrets (secrets/pg_password.txt);
# the URL below uses the container service name as the host.
DATABASE_URL=postgres://assessiq:CHANGE_ME@localhost:5432/assessiq

# ---- Cache / Queue (Redis 7) ----
REDIS_URL=redis://localhost:6379

# ---- Master encryption key ----
# 32 bytes, base64-encoded. Used for AES-256-GCM envelope encryption of
# TOTP secrets, recovery codes, embed JWT secrets, and webhook signing keys.
# Generate: openssl rand -base64 32
ASSESSIQ_MASTER_KEY=

# ---- Session ----
# 32 bytes, base64-encoded. Signs the session cookie.
# Generate: openssl rand -base64 32
SESSION_SECRET=
SESSION_COOKIE_NAME=aiq_sess

# ---- Embed JWT ----
# Controls how per-tenant embed secrets are provisioned.
# Allowed values: per-tenant (default) | shared (dev only)
EMBED_JWT_SECRET_PROVISION_MODE=per-tenant

# ---- Google OAuth (admin SSO) ----
# Provision at console.cloud.google.com → APIs & Services → Credentials.
# Redirect URI must match exactly: https://assessiq.automateedge.cloud/api/auth/google/cb
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production: https://assessiq.automateedge.cloud/api/auth/google/cb
# Local dev:  http://localhost:3000/api/auth/google/cb
GOOGLE_OAUTH_REDIRECT=https://assessiq.automateedge.cloud/api/auth/google/cb

# ---- MFA gate ----
# true (production hardening) = admins/reviewers must complete TOTP after
# Google SSO before accessing protected routes; pre-MFA sessions land on
# /admin/mfa for enrolment.
# false (early-stage simplification) = Google SSO is the sole auth factor;
# requireAuth bypasses the totpVerified + freshMfa gates and the SSO callback
# redirects past /admin/mfa to returnTo or /admin/users.
# Flip to true once /admin/mfa enrolment UX has been browser-tested end-to-end.
# Existing sessions then re-prompt for TOTP because totpVerified stays false.
MFA_REQUIRED=true

# ---- Origin-verify anti-IP-spoof ----
# Shared secret Cloudflare injects as the x-origin-verify request header via a
# Cloudflare Transform Rule. The API trusts cf-connecting-ip only when this
# header is present and matches. Leave blank in dev/test/CI — boot works without it.
# Generate: openssl rand -hex 32
ORIGIN_VERIFY_SECRET=

# Controls how strictly the origin-verify header is enforced.
# Rollout order: off → log → enforce
#   off     (default) — legacy: trust cf-connecting-ip ?? req.ip, zero validation.
#                       Deploy this first; no behaviour changes until you move to log.
#   log     — same return value as off, but emits a structured warn when the
#             x-origin-verify header is absent or mismatched. Use to confirm
#             the Cloudflare Transform Rule is delivering the header correctly
#             before flipping to enforce.
#   enforce — only trusts cf-connecting-ip when x-origin-verify passes a
#             constant-time compare against ORIGIN_VERIFY_SECRET. On mismatch,
#             falls back to raw socket IP; cf-connecting-ip / x-forwarded-for
#             are ignored entirely.
ORIGIN_TRUST_MODE=off

# ---- Rate limiting (IP buckets) ----
# All four vars are optional — Zod defaults produce the values below.
# Adjust in .env to tune per tier without a code change or image rebuild.
# Tier (session role)             Default    Env var
# admin / reviewer session        100/min/IP  RATE_LIMIT_IP_ADMIN
# candidate session                30/min/IP  RATE_LIMIT_IP_USER
# anonymous (no session / key)     30/min/IP  RATE_LIMIT_IP_ANON
# API key (Bearer aiq_live_*)     600/min/IP  RATE_LIMIT_IP_APIKEY
RATE_LIMIT_IP_ADMIN=100
RATE_LIMIT_IP_USER=30
RATE_LIMIT_IP_ANON=30
RATE_LIMIT_IP_APIKEY=600

# ---- Email (SMTP) ----
# Phase 3 only. In development, emails are written to /var/log/assessiq/dev-emails.log.
# Format: smtps://user:pass@smtp.host:465  or  smtp://user:pass@smtp.host:587
SMTP_URL=
EMAIL_FROM="AssessIQ <noreply@automateedge.cloud>"

# ---- AI pipeline ----
# Controls which grading backend is active.
# Phase 1: claude-code-vps — grading runs as Claude Code CLI on the VPS
#           under the admin's Max subscription (sync-on-click, admin-in-the-loop).
# Phase 2: anthropic-api   — switches to a budgeted Anthropic API key
#           via @anthropic-ai/sdk in modules/07-ai-grading/runtimes/anthropic-api.ts.
AI_PIPELINE_MODE=claude-code-vps

# Controls the question-generation strategy introduced in Stage 1 type-sharded
# generation (docs/design/2026-05-09-type-sharded-generation.md).
# omnibus (default) — legacy single-skill generate-questions call for all types.
# sharded — fans out to per-type skills (generate-mcq, generate-log-analysis,
#            generate-scenario, generate-kql) with auto-weighted counts and
#            a 2-concurrent semaphore.
# Do NOT set to "sharded" until per-type skills are deployed on the VPS and
# Stage 1.5 evals pass. See modules/00-core/src/config.ts for Zod enum.
# Per-tenant column (ai_generate_mode) overrides this env var when non-NULL.
AI_GENERATE_MODE=omnibus

# ──────────────────────────────────────────────────────────────────────────────
# WARNING — DO NOT ADD ANTHROPIC_API_KEY HERE
#
# Phase 1 grading runs as the Claude Code CLI on the VPS under the admin's
# personal Max account subscription. There is NO Anthropic API key in Phase 1.
# Adding ANTHROPIC_API_KEY to this file or to any module's env is a hard-rule
# violation (CLAUDE.md rule #1 and docs/05-ai-pipeline.md § Compliance frame).
#
# Phase 2 will introduce a budgeted key, gated behind AI_PIPELINE_MODE=anthropic-api
# and imported only in modules/07-ai-grading/runtimes/anthropic-api.ts.
# ──────────────────────────────────────────────────────────────────────────────

# ---- AI grading eval ----
# Optional. Override the admin user id used for eval CLI runs
# (modules/07-ai-grading/eval/cli.ts). Unset = eval CLI derives it from DB.
AIQ_ADMIN_USER_ID=

# ---- Audit-log archival ----
# S3 bucket for audit-log cold archival (modules/14-audit-log/src/archive-job.ts).
S3_BUCKET=

# ---- Test minters (dev only) ----
# WARNING: both must be false (or unset) in production.
# ENABLE_EMBED_TEST_MINTER exposes a dev-only embed-session minting endpoint
# (apps/api/src/routes/auth/embed.ts).
ENABLE_EMBED_TEST_MINTER=false
# ENABLE_E2E_TEST_MINTER exposes a dev-only E2E session minting endpoint;
# guarded by a hard prod check in config.ts (commit bd0ceb0).
ENABLE_E2E_TEST_MINTER=false

# ---- Dev / test only ----
# Dev-only email log path used by lifecycle tests
# (modules/05-assessment-lifecycle/src/__tests__/lifecycle.test.ts).
ASSESSIQ_DEV_EMAILS_LOG=

# ---- E2E (Playwright) ----
# Base URL the Playwright runner targets (apps/web/e2e/fixtures/factories.ts).
PLAYWRIGHT_BASE_URL=http://localhost:5173
# API base URL used by E2E fixtures (apps/web/e2e/fixtures/factories.ts).
E2E_API_BASE_URL=http://localhost:3000
# Pre-minted candidate session token for the take-happy-path spec
# (apps/web/e2e/take-happy-path.spec.ts). Leave empty; populated by the test minter.
E2E_CANDIDATE_TOKEN=
