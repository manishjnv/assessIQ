# ---- Domain ----
ASSESSIQ_BASE_URL=https://assessiq.automateedge.cloud
NODE_ENV=development

# ---- Observability ----
LOG_LEVEL=info
SENTRY_DSN=

# ---- Database (PostgreSQL 16) ----
# For local dev, point at a local Postgres or the Docker service.
# For production, the password is read from Docker secrets (secrets/pg_password.txt);
# the URL below uses the container service name as the host.
DATABASE_URL=postgres://assessiq:CHANGE_ME@localhost:5432/assessiq

# ---- Cache / Queue (Redis 7) ----
REDIS_URL=redis://localhost:6379

# ---- Master encryption key ----
# 32 bytes, base64-encoded. Used for AES-256-GCM envelope encryption of
# TOTP secrets, recovery codes, embed JWT secrets, and webhook signing keys.
# Generate: openssl rand -base64 32
ASSESSIQ_MASTER_KEY=

# ---- Session ----
# 32 bytes, base64-encoded. Signs the session cookie.
# Generate: openssl rand -base64 32
SESSION_SECRET=
SESSION_COOKIE_NAME=aiq_sess

# ---- Embed JWT ----
# Controls how per-tenant embed secrets are provisioned.
# Allowed values: per-tenant (default) | shared (dev only)
EMBED_JWT_SECRET_PROVISION_MODE=per-tenant

# ---- Google OAuth (admin SSO) ----
# Provision at console.cloud.google.com → APIs & Services → Credentials.
# Redirect URI must match exactly: https://assessiq.automateedge.cloud/api/auth/google/cb
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=https://assessiq.automateedge.cloud/api/auth/google/cb

# ---- MFA gate ----
# true (production hardening) = admins/reviewers must complete TOTP after
# Google SSO before accessing protected routes; pre-MFA sessions land on
# /admin/mfa for enrolment.
# false (early-stage simplification) = Google SSO is the sole auth factor;
# requireAuth bypasses the totpVerified + freshMfa gates and the SSO callback
# redirects past /admin/mfa to returnTo or /admin/users.
# Flip to true once /admin/mfa enrolment UX has been browser-tested end-to-end.
# Existing sessions then re-prompt for TOTP because totpVerified stays false.
MFA_REQUIRED=true

# ---- Email (SMTP) ----
# Phase 3 only. In development, emails are written to /var/log/assessiq/dev-emails.log.
# Format: smtps://user:pass@smtp.host:465  or  smtp://user:pass@smtp.host:587
SMTP_URL=
EMAIL_FROM="AssessIQ <noreply@automateedge.cloud>"

# ---- AI pipeline ----
# Controls which grading backend is active.
# Phase 1: claude-code-vps — grading runs as Claude Code CLI on the VPS
#           under the admin's Max subscription (sync-on-click, admin-in-the-loop).
# Phase 2: anthropic-api   — switches to a budgeted Anthropic API key
#           via @anthropic-ai/sdk in modules/07-ai-grading/runtimes/anthropic-api.ts.
AI_PIPELINE_MODE=claude-code-vps

# ──────────────────────────────────────────────────────────────────────────────
# WARNING — DO NOT ADD ANTHROPIC_API_KEY HERE
#
# Phase 1 grading runs as the Claude Code CLI on the VPS under the admin's
# personal Max account subscription. There is NO Anthropic API key in Phase 1.
# Adding ANTHROPIC_API_KEY to this file or to any module's env is a hard-rule
# violation (CLAUDE.md rule #1 and docs/05-ai-pipeline.md § Compliance frame).
#
# Phase 2 will introduce a budgeted key, gated behind AI_PIPELINE_MODE=anthropic-api
# and imported only in modules/07-ai-grading/runtimes/anthropic-api.ts.
# ──────────────────────────────────────────────────────────────────────────────
